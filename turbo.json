{
  "$schema": "https://turborepo.dev/schema.v2.json",
  "ui": "tui",
  "globalEnv": [
    "DOMAIN_NAME",
    "BASE_URL",
    "DATABASE_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "PLUNK_SECRET_KEY",
    "RESEND_API_KEY",
    "STORAGE_REGION",
    "STORAGE_BUCKET_NAME",
    "NEXT_PUBLIC_STORAGE_BASE_URL",
    "R2_ACCOUNT_ID",
    "R2_ACCESS_KEY_ID",
    "R2_SECRET_ACCESS_KEY",
    "AWS_ACCESS_KEY_ID",
    "AWS_BUCKET_NAME",
    "AWS_SECRET_ACCESS_KEY",
    "NEXT_PUBLIC_FF_API_KEY",
    "NEXT_PUBLIC_FF_API_ORIGIN",
    "NEXT_PUBLIC_IS_CLOUD",
    "INNGEST_EVENT_KEY",
    "INNGEST_SIGNING_KEY",
    "GITHUB_APP_ID",
    "GITHUB_PRIVATE_KEY",
    "GITHUB_WEBHOOK_SECRET",
    "LINEAR_CLIENT_ID",
    "LINEAR_CLIENT_SECRET",
    "LINEAR_OAUTH_REDIRECT_URI",
    "LINEAR_WEBHOOK_SIGNING_SECRET",
    "LINEAR_TOKEN_ENCRYPTION_KEY",
    "SLACK_CLIENT_ID",
    "SLACK_CLIENT_SECRET",
    "SLACK_TOKEN_ENCRYPTION_KEY",
    "NEXT_PUBLIC_STRIPE_PUBLIC_KEY",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SIGNING_SECRET",
    "STRIPE_DEFAULT_TAX_RATE_ID",
    "PRO_MONTHLY_PRICE_ID",
    "PRO_YEARLY_PRICE_ID",
    "AGENCY_MONTHLY_PRICE_ID",
    "AGENCY_YEARLY_PRICE_ID",
    "AWS_REGION",
    "NODE_ENV",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL",
    "VERCEL_PROJECT_PRODUCTION_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "lint": {
      "dependsOn": ["transit"]
    },
    "lint:agent-rules": {},
    "typecheck": {
      "dependsOn": ["transit"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
